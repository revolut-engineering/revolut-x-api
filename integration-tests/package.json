{
  "name": "revolutx-integration-tests",
  "version": "1.0.34",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "vitest run --config vitest.unit.config.ts",
    "test:watch": "vitest --config vitest.unit.config.ts",
    "test:coverage": "vitest run --config vitest.unit.config.ts --coverage",
    "test:agent": "vitest run",
    "test:agent:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/ evals/",
    "lint:fix": "eslint src/ tests/ evals/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"evals/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"evals/**/*.ts\""
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.91.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@xenova/transformers": "^2.17.2",
    "dotenv": "^16.4.5",
    "openai": "^4.79.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.4",
    "zod": "^3.23.0"
  }
}
