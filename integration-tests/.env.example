# Copy this file to .env and fill in. Variables already set in your shell
# environment win over .env (override: false in vitest.config.ts).

# ────────────────────────────────────────────────────────────────────────────
# Required
# ────────────────────────────────────────────────────────────────────────────

# Anthropic API key — required for the agent and for a.judge assertions.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ────────────────────────────────────────────────────────────────────────────
# Embedding provider
# ────────────────────────────────────────────────────────────────────────────

# Embedding provider: "local" (default, no extra key, ~30MB local model) or
# "openai" (hosted, requires OPENAI_API_KEY).
# EVAL_EMBEDDING_PROVIDER=local

# Override the embedding model id. Defaults:
#   local  → Xenova/all-MiniLM-L6-v2
#   openai → text-embedding-3-small
# EVAL_EMBEDDING_MODEL=

# OpenAI API key — required only when EVAL_EMBEDDING_PROVIDER=openai.
# OPENAI_API_KEY=sk-...

# ────────────────────────────────────────────────────────────────────────────
# Eval run shape
# ────────────────────────────────────────────────────────────────────────────

# Trials per case. More trials = more confidence in pass rate, more cost.
# EVAL_REPETITIONS=3

# Min pass rate (passes/trials) for a case to "pass" overall.
# 0.667 ≈ 2 of 3 trials must pass.
# EVAL_PASS_THRESHOLD=0.667

# Agent model. Pin to a specific snapshot for stable evals over time.
# EVAL_MODEL=claude-opus-4-7

# Per-trial loop budget — max model turns before runAgent throws.
# Per-case override: defineEval({ maxIterations: 6, ... }).
# (no env var; controlled per-case)

# ────────────────────────────────────────────────────────────────────────────
# LLM-as-judge (a.judge assertions)
# ────────────────────────────────────────────────────────────────────────────

# Model used by a.judge assertions. Sonnet is the recommended default —
# strong scoring, ~5× cheaper than Opus.
# EVAL_JUDGE_MODEL=claude-sonnet-4-6

# Max tokens for the judge's JSON response.
# EVAL_JUDGE_MAX_TOKENS=512

# ────────────────────────────────────────────────────────────────────────────
# Reporting
# ────────────────────────────────────────────────────────────────────────────

# Run identifier — defaults to a timestamp. Override to pin runs to a label
# (useful in CI where you want a known directory).
# EVAL_RUN_ID=local-dev

# Override the per-run report directory. Defaults to
# integration-tests/reports/run-<EVAL_RUN_ID>.
# EVAL_REPORT_DIR=

# Logs a warning at the end of a run if total cost (agent + judge + embed)
# exceeds this cap.
# EVAL_COST_CAP_USD=5
